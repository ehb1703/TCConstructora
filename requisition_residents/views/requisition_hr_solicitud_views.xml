<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_requisition_hr_solicitud" model="ir.actions.act_window">
        <field name="name">Solicitudes</field>
        <field name="res_model">requisition.hr.solicitud</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_requisition_hr_solicitud_list" model="ir.ui.view">
        <field name="name">view.requisition.hr.solicitud.list</field>
        <field name="model">requisition.hr.solicitud</field>
        <field name="arch" type="xml">
            <list string="Solicitudes">
                <field name="nombre"/>
                <field name="apellido_paterno"/>
                <field name="apellido_materno"/>
                <field name="codigo_postal"/>
                <field name="tipo_tramite"/>
                <field name="fecha_aplicacion"/>
                <field name="nss"/>
                <field name="rfc"/>
                <field name="curp"/>
                <field name="genero"/>
                <field name="fecha_nacimiento"/>
                <field name="ciudad_nacimiento"/>
                <field name="observaciones"/>
            </list>
        </field>
    </record>

    <record id="view_requisition_hr_solicitud_form" model="ir.ui.view">
        <field name="name">view.requisition.hr.solicitud.form</field>
        <field name="model">requisition.hr.solicitud</field>
        <field name="arch" type="xml">
            <form string="Solicitud">
                <header>
                    <button string="Enviar" name="action_send" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button string="Aprobar" name="action_confirm" type="object" class="btn-primary" invisible="state != 'send'" groups="requisition_residents.group_requisition_admin"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="employee_domain" invisible="1"/>
                        <group>
                            <field name="tipo_tramite"/>
                        </group>
                        <group>
                            <field name="fecha_aplicacion" required="tipo_tramite in ['alta', 'baja']"/>
                            <field name="departure_reason_id" invisible="tipo_tramite != 'baja'"/>
                        </group>
                        <group>    
                            <field name="employee_id" invisible="tipo_tramite == 'alta'" required="tipo_tramite != 'alta'" options="{'no_open':True, 'no_create':True, 'no_edit':True}" context="{'special_display':True}" domain="employee_domain"/>
                            <field name="nombre" readonly="tipo_tramite != 'alta'" force_save="1"/>
                            <field name="apellido_paterno" readonly="tipo_tramite != 'alta'" force_save="1"/>
                            <field name="apellido_materno" readonly="tipo_tramite != 'alta'" force_save="1"/>
                            <field name="genero" readonly="tipo_tramite not in ['alta', 'actualizacion']" force_save="1"/>
                        </group>
                        <group>
                            <field name="fecha_nacimiento" readonly="tipo_tramite not in ['alta', 'actualizacion']" force_save="1"/>
                            <field name="ciudad_nacimiento" readonly="tipo_tramite not in ['alta', 'actualizacion']" force_save="1"/>
                            <field name="nss" readonly="tipo_tramite not in ['alta', 'actualizacion']" force_save="1"/>
                            <field name="rfc" readonly="tipo_tramite not in ['alta', 'actualizacion']" force_save="1"/>
                            <field name="curp" readonly="tipo_tramite not in ['alta', 'actualizacion']" force_save="1" required="tipo_tramite == 'alta'"/>
                        </group>
                        <group string="Dirección" invisible="tipo_tramite in ['baja', 'rehabilitacion']">
                            <field name="calle" readonly="tipo_tramite not in ['alta', 'actualizacion']" force_save="1"/>
                            <field name="colonia" readonly="tipo_tramite not in ['alta', 'actualizacion']" force_save="1"/>
                            <field name="codigo_postal" readonly="tipo_tramite not in ['alta', 'actualizacion']" force_save="1"/>
                            <field name="estado_id" readonly="tipo_tramite not in ['alta', 'actualizacion']" force_save="1"/>
                            <field name="municipio_id" domain="[('state_id','=',estado_id)]" options="{'no_open':True, 'no_create':True, 'no_edit':True}" force_save="1"/>
                        </group>
                        <group string="Método de pago" invisible="tipo_tramite in ['baja', 'rehabilitacion', 'actualizacion']">
                            <field name="res_bank" readonly="tipo_tramite != 'alta'" options="{'no_open':True, 'no_create':True, 'no_edit':True}" force_save="1"/>
                            <field name="notarjeta" readonly="tipo_tramite != 'alta'" force_save="1"/>
                            <field name="clabe" readonly="tipo_tramite != 'alta'" force_save="1"/>
                            <field name="nocuenta" readonly="tipo_tramite != 'alta'" force_save="1"/>
                            <field name="type_pay" invisible="state == 'draft'" groups="requisition_residents.group_requisition_admin"/>
                        </group>
                        <group string="Contrato" colspan="2" invisible="tipo_tramite in ['baja', 'rehabilitacion', 'actualizacion']">
                            <group>
                                <field name="company_id" invisible="state == 'draft'" groups="requisition_residents.group_requisition_admin" required="tipo_tramite in ['alta', 'rehabilitacion']" options="{'no_open':True, 'no_create':True, 'no_edit':True}"/>
                                <field name="project_id" options="{'no_open':True, 'no_create':True, 'no_edit':True}" required="tipo_tramite in ['alta', 'rehabilitacion']"/>
                                <field name="job_id" options="{'no_open':True, 'no_create':True, 'no_edit':True}" required="tipo_tramite in ['alta', 'rehabilitacion']"/>
                            </group>
                            <group>
                                <field name="resource_calendar_id" options="{'no_open':True, 'no_create':True, 'no_edit':True}" required="tipo_tramite in ['alta', 'rehabilitacion']"/>
                                <field name="salary" invisible="state == 'draft'" required="tipo_tramite in ['alta', 'rehabilitacion']"/>
                            </group>
                        </group>
                    </group>
                    <group>
                        <field name="observaciones" string="Observaciones"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <menuitem id="menu_tramites_rh" name="Trámites RH" parent="reports_menu_root" groups="group_requisition_admin,group_requisition_capture" sequence="15">
        <menuitem id="menu_hr_solicitudes" name="Solicitudes" action="action_requisition_hr_solicitud" groups="group_requisition_admin,group_requisition_capture" sequence="10"/>
    </menuitem>
</odoo>
