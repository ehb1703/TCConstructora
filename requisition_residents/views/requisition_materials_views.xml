<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_requisition_materials" model="ir.actions.act_window">
        <field name="name">Materiales</field>
        <field name="res_model">requisition.materials</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

    <record id="view_requisition_materials_list" model="ir.ui.view">
        <field name="name">view.requisition.materials.list</field>
        <field name="model">requisition.materials</field>
        <field name="priority" eval="1"/>
        <field name="arch" type="xml">
            <list string="Materiales" delete="0">
                <field name="name"/>
                <field name="project_id"/>
                <field name="employee_id"/>
            </list>
        </field>
    </record>

    <record id="view_requisition_materials_form" model="ir.ui.view">
        <field name="name">view.requisition.materials.form</field>
        <field name="model">requisition.materials</field>
        <field name="arch" type="xml">
            <form string="Materiales" delete="0">
                <header>
                    <button string="Enviar" name="action_send" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button string="Aprobar" name="action_confirm" type="object" class="btn-primary" invisible="state != 'send'" groups="requisition_residents.group_materials_authorize"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id" invisible="state == 'draft'" readonly="state != 'draft'" context="{'special_display':True}"/>
                            <field name="project_id"/>
                            <field name="company_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Productos">
                            <field name="line_ids" widget="one2many_list">
                                <list create="true" delete="true" editable="bottom" context="{'default_req_id': id}">
                                    <field name="req_id" column_invisible="1"/>
                                    <field name="urgencia"/>
                                    <field name="product_id"/>
                                    <field name="product_uom_id" readonly="1"/>
                                    <field name="product_qty"/>
                                    <field name="supplier_ids" widget="many2many_tags" groups="requisition_residents.group_materials_authorize"/>
                                </list>
                                <form><p>Información no disponible a través de esta vista</p></form>
                            </field>
                        </page>
                        <page string="Órdenes de compra" groups="requisition_residents.group_materials_authorize">
                            <field name="oc_ids" widget="one2many_list">
                                <list string="Ordenes de compra" delete="0" create="0" edit="0" context="{'default_materials_id': id}">
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="type_purchase"/>
                                    <field name="amount_untaxed"/>
                                    <field name="amount_total"/>
                                    <field name="state"/>
                                </list>
                                <form><p>Información no disponible a través de esta vista</p></form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_purchase_order_materials_from" model="ir.ui.view">
        <field name="name">view.purchase.order.materials.from</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="project_extra.view_purchase_order_lead_from"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lead_id']" position="replace">
                <field name="lead_id" invisible="type_purchase == 'mat'" options="{'no_open':True, 'no_create':True, 'no_edit':True}"/>
                <field name="materials_id" invisible="type_purchase != 'mat'" options="{'no_open':True, 'no_create':True, 'no_edit':True}"/>
            </xpath>
            <xpath expr="//field[@name='empresa_solicitante']" position="replace">
                <field name="empresa_solicitante" invisible="type_purchase not in ['bases', 'mat']" readonly="1"/>
            </xpath>
        </field>
    </record>

    <menuitem id="menu_requisition_materials" name="Requerimiento de Materiales" action="action_requisition_materials" parent="menu_requisiciones" sequence="20"/>
</odoo>
