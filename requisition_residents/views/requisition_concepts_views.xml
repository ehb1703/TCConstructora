<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_requisition_concepts" model="ir.actions.act_window">
        <field name="name">Conceptos Extraordinarios</field>
        <field name="res_model">requisition.request.concept</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

    <record id="view_requisition_concepts_list" model="ir.ui.view">
        <field name="name">view.requisition.concepts.list</field>
        <field name="model">requisition.request.concept</field>
        <field name="priority" eval="1"/>
        <field name="arch" type="xml">
            <list string="Conceptos Extraordinarios" delete="0">
                <field name="codigo"/>
                <field name="description"/>
                <field name="project_id"/>
            </list>
        </field>
    </record>

    <record id="view_requisition_concepts_form" model="ir.ui.view">
        <field name="name">view.requisition.concepts.form</field>
        <field name="model">requisition.request.concept</field>
        <field name="arch" type="xml">
            <form string="Conceptos Extraordinarios" delete="0" duplicate="0">
                <header>
                    <button string="Revisión" name="action_review" type="object" class="btn-primary" invisible="state != 'draft' or not state"/>
                    <button string="Costos" name="action_costos" type="object" class="btn-primary" invisible="state != 'revision'" groups="requisition_residents.group_encargado"/>
                    <button string="Aprobar" name="action_confirm" type="object" class="btn-primary" invisible="state != 'costos'" groups="requisition_residents.group_costos"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <field name="project_domain" invisible="1"/>
                    <group>
                        <group>
                            <field name="tipo" required="1" readonly="state == 'aprobado'"/>
                            <field name="product_id" readonly="1" invisible="state != 'aprobado'" options="{'no_open':True, 'no_create':True, 'no_edit':True}"/>
                        </group>
                        <group>
                            <field name="project_id" required="1" readonly="state == 'aprobado'" options="{'no_open':True, 'no_create':True, 'no_edit':True}"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="codigo" required="state == 'costos'" readonly="state == 'aprobado'"/>
                            <field name="description" required="state == 'costos'" readonly="state == 'aprobado'"/>
                        </group>
                        <group>
                            <field name="uom_id" required="state == 'costos'" readonly="state == 'aprobado'" options="{'no_open':True, 'no_create':True, 'no_edit':True}"/>
                            <field name="price" required="state == 'costos'" readonly="state == 'aprobado'"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <menuitem id="menu_requisition_concepts" name="Conceptos Extraordinarios" action="action_requisition_concepts" parent="menu_requisiciones" sequence="28" groups="requisition_residents.group_requisition_capture,requisition_residents.group_encargado,requisition_residents.group_costos"/>
</odoo>
