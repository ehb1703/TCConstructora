<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_requisition_concepts" model="ir.actions.act_window">
        <field name="name">Conceptos Extraordinarios</field>
        <field name="res_model">requisition.request.concept</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

    <record id="view_requisition_concepts_list" model="ir.ui.view">
        <field name="name">view.requisition.concepts.list</field>
        <field name="model">requisition.request.concept</field>
        <field name="priority" eval="1"/>
        <field name="arch" type="xml">
            <list string="Conceptos Extraordinarios" delete="0">
                <field name="codigo"/>
                <field name="description"/>
                <field name="project_id"/>
            </list>
        </field>
    </record>

    <record id="view_requisition_concepts_form" model="ir.ui.view">
        <field name="name">view.requisition.concepts.form</field>
        <field name="model">requisition.request.concept</field>
        <field name="arch" type="xml">
            <form string="Conceptos Extraordinarios" delete="0">
                <header>
                    <!--button string="Enviar" name="action_send" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button string="Aprobar" name="action_confirm" type="object" class="btn-primary" invisible="state != 'send'" groups="requisition_residents.group_materials_authorize"/-->
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <field name="project_domain" invisible="1"/>
                    <group>
                        <group>
                            <field name="tipo"/>
                        </group>
                        <group>
                            <field name="project_id"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="codigo"/>
                            <field name="description"/>
                        </group>
                        <group>
                            <field name="uom_id"/>
                            <field name="price"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <menuitem id="menu_requisition_concepts" name="Conceptos Extraordinarios" action="action_requisition_concepts" parent="menu_requisiciones" sequence="28"/>
</odoo>