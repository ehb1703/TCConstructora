<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="filter_lead_default" model="ir.filters">
        <field name="name">Oportunidades</field>
        <field name="model_id">purchase.order</field>
        <field name="context">{'group_by': ['lead_id', 'type_purchase']}</field>
    </record>

    <record id="view_purchase_order_lead_from" model="ir.ui.view">
        <field name="name">view.purchase.order.lead.from</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='button_draft']" position="after">
                <button name="action_comparativo" type="object" string="Comparativo" class="btn-secondary" invisible="state != 'sent' or type_purchase != 'ins'"/>
            </xpath>

            <xpath expr="//field[@name='currency_id']" position="after">
                <field name="type_purchase"/>
                <field name="lead_id"/>
                <field name="empresa_solicitante" invisible="type_purchase != 'bases'" readonly="1"/>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="Bitácora" name="bitacora">
                    <field name="bitacora_ids" nolabel="1" readonly="1">
                        <list>
                            <field name="fecha" string="Fecha"/>
                            <field name="usuario" string="Usuario"/>
                            <field name="etapa_anterior" string="Etapa anterior"/>
                            <field name="etapa_nueva" string="Etapa nueva"/>
                            <field name="motivo_id" string="Motivo" readonly="0"/>
                            <field name="observaciones" string="Observaciones" readonly="0"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_purchase_requisition_report_from" model="ir.ui.view">
        <field name="name">view.purchase.requisition.report.from</field>
        <field name="model">purchase.requisition</field>
        <field name="inherit_id" ref="purchase_requisition.view_purchase_requisition_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group" position="after">
                <group>
                    <field name="description_contract"/>
                    <field name="doctos_delivered"/>
                </group>
                <group>
                    <group>
                        <field name="retencion"/>
                        <field name="schedule"/>
                    </group>
                    <group>
                        <field name="warranty_period"/>
                        <field name="signature_date"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Asignación de solicitudes de cotización -->
    <record id="action_purchase_asignacion" model="ir.actions.act_window">
        <field name="name">Asignación de solicitudes de cotización</field>
        <field name="res_model">purchase.asignacion</field>
        <field name="view_mode">list</field>
    </record>

    <record id="view_purchase_asignacion_list" model="ir.ui.view">
        <field name="name">view.purchase.asignacion.list</field>
        <field name="model">purchase.asignacion</field>
        <field name="arch" type="xml">
            <list string="Asignación de solicitudes de cotización" editable="top">
                <field name="nombre_id" options="{'no_create':True, 'no_edit':True}"/>
                <field name="referencia_id" options="{'no_create':True, 'no_edit':True}"/>
                <field name="fecha_asignacion"/>
                <field name="fecha_limite"/>
                <field name="observaciones"/>
            </list>
        </field>
    </record>

    <menuitem id="menu_purchase_asignacion" name="Asignación" parent="purchase.menu_procurement_management" action="action_purchase_asignacion" sequence="2"/>
</odoo>
